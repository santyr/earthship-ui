{
  "schema": "earthship-openhab-managed-resources/v1",
  "subsets": {
    "feeder": {
      "capability": "feeder-request-v1",
      "items": [
        {
          "name": "GoatFeeder_ManualRequest",
          "type": "String",
          "label": "Goat feeder manual request",
          "category": "",
          "tags": [],
          "groupNames": []
        },
        {
          "name": "GoatFeeder_ManualResult",
          "type": "String",
          "label": "Goat feeder manual result",
          "category": "",
          "tags": [],
          "groupNames": []
        }
      ],
      "metadata": [
        {
          "item": "GoatFeeder_ManualRequest",
          "namespace": "autoupdate",
          "value": "false",
          "config": {}
        },
        {
          "item": "Goat_Plugs_Outlet2_Switch",
          "namespace": "expire",
          "value": "0h0m1s,command=OFF",
          "config": {}
        }
      ],
      "persistence": {
        "serviceId": "jdbc",
        "strategy": "everyChange",
        "restoreOnStartup": true,
        "items": [
          "GoatFeeder_ManualRequest",
          "GoatFeeder_ManualResult"
        ]
      },
      "rule": {
        "uid": "88bd9ec4de",
        "name": "Feeder Timer",
        "source": "openhab/rules/feeder-owner.js",
        "triggers": [
          {
            "id": "earthship-feeder-manual-request",
            "type": "core.ItemCommandTrigger",
            "configuration": {
              "itemName": "GoatFeeder_ManualRequest"
            }
          }
        ],
        "action": {
          "id": "earthship-feeder-owner",
          "type": "script.ScriptAction",
          "configuration": {
            "type": "application/javascript;version=ECMAScript-2021"
          }
        }
      },
      "protectedDependencies": [
        "Goat_Plugs_Outlet2_Switch",
        "GoatFeedings"
      ]
    },
    "greywater": {
      "capability": "greywater-request-v1",
      "items": [
        {
          "name": "SouthOutlet_ManualRequest",
          "type": "String",
          "label": "South outlet manual request",
          "category": "",
          "tags": [],
          "groupNames": []
        },
        {
          "name": "SouthOutlet_ManualResult",
          "type": "String",
          "label": "South outlet manual result",
          "category": "",
          "tags": [],
          "groupNames": []
        },
        {
          "name": "SouthOutlet_LastCycleStart",
          "type": "DateTime",
          "label": "South outlet last cycle start",
          "category": "",
          "tags": [],
          "groupNames": []
        },
        {
          "name": "SouthOutlet_LastCycle",
          "type": "String",
          "label": "South outlet last completed cycle",
          "category": "",
          "tags": [],
          "groupNames": []
        }
      ],
      "metadata": [
        {
          "item": "SouthOutlet_ManualRequest",
          "namespace": "autoupdate",
          "value": "false",
          "config": {}
        }
      ],
      "persistence": {
        "serviceId": "jdbc",
        "strategy": "everyChange",
        "restoreOnStartup": true,
        "items": [
          "SouthOutlet_ManualRequest",
          "SouthOutlet_ManualResult",
          "SouthOutlet_LastCycleStart",
          "SouthOutlet_LastCycle"
        ]
      },
      "rule": {
        "uid": "hex_southoutlet_cycle",
        "name": "SouthOutlet SOC-Gated Cycle",
        "source": "openhab/rules/southoutlet-cycle.js",
        "triggers": [
          {
            "id": "1",
            "type": "core.ItemStateChangeTrigger",
            "configuration": {
              "itemName": "DCData_Voltage"
            }
          },
          {
            "id": "2",
            "type": "core.ItemStateChangeTrigger",
            "configuration": {
              "itemName": "BMS_SOC"
            }
          },
          {
            "id": "cron",
            "type": "timer.GenericCronTrigger",
            "configuration": {
              "cronExpression": "0 */5 * * * ?"
            }
          },
          {
            "id": "earthship-southoutlet-manual-request",
            "type": "core.ItemCommandTrigger",
            "configuration": {
              "itemName": "SouthOutlet_ManualRequest"
            }
          }
        ],
        "action": {
          "id": "earthship-southoutlet-owner",
          "type": "script.ScriptAction",
          "configuration": {
            "type": "application/javascript;version=ECMAScript-2021"
          }
        }
      },
      "protectedDependencies": [
        "SouthOutlet_Outlet2_Switch",
        "SouthOutlet_LastAutoRun",
        "SouthOutlet_AutoStatus",
        "SouthOutlet_LowSocCutoff",
        "BMS_SOC",
        "BMS_Comms_Status",
        "DCData_Voltage",
        "SkyCondition",
        "Sun_Position_Elevation"
      ]
    }
  }
}
